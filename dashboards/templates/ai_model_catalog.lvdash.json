{
 "datasets": [
  {
   "name": "ds_total_models",
   "displayName": "ai_models_total",
   "query": "SELECT COUNT(*) AS models FROM {catalog}.{schema}.ai_model_catalog WHERE is_current AND entity_type != 'ACCOUNT'"
  },
  {
   "name": "ds_models_by_source",
   "displayName": "ai_models_by_source",
   "query": "SELECT source, COUNT(*) AS models FROM {catalog}.{schema}.ai_model_catalog WHERE is_current AND entity_type != 'ACCOUNT' GROUP BY source ORDER BY models DESC"
  },
  {
   "name": "ds_models_by_provider",
   "displayName": "ai_models_by_provider",
   "query": "SELECT provider, COUNT(*) AS models FROM {catalog}.{schema}.ai_model_catalog WHERE is_current AND entity_type != 'ACCOUNT' GROUP BY provider ORDER BY models DESC"
  },
  {
   "name": "ds_key_auth_accounts",
   "displayName": "azure_accounts_with_key_auth",
   "query": "SELECT endpoint_name AS account, subscription_id, region, resource_id FROM {catalog}.{schema}.ai_model_catalog WHERE is_current AND source = 'azure_openai' AND entity_type = 'ACCOUNT' AND key_auth_enabled ORDER BY account"
  },
  {
   "name": "ds_access_levels",
   "displayName": "ai_access_by_level",
   "query": "SELECT source, access_level, COUNT(*) AS grants FROM {catalog}.{schema}.ai_model_access WHERE is_current GROUP BY source, access_level ORDER BY grants DESC"
  },
  {
   "name": "ds_top_principals",
   "displayName": "ai_top_principals",
   "query": "SELECT principal_name, source, COUNT(DISTINCT model_key) AS models FROM {catalog}.{schema}.ai_model_access WHERE is_current AND access_level IN ('INVOKE', 'ADMIN', 'CAN_QUERY', 'CAN_MANAGE') GROUP BY principal_name, source ORDER BY models DESC LIMIT 20"
  },
  {
   "name": "ds_model_inventory",
   "displayName": "ai_model_inventory",
   "query": "SELECT source, model_name, model_version, provider, entity_type, endpoint_name, status, region, owner, last_seen_at FROM {catalog}.{schema}.ai_model_catalog WHERE is_current AND entity_type != 'ACCOUNT' ORDER BY source, model_name LIMIT 500"
  },
  {
   "name": "ds_findings",
   "displayName": "ai_catalog_findings",
   "query": "SELECT run_ts, check_name, resource, reason, action FROM {catalog}.{schema}.platform_findings WHERE area = 'ai-catalog' AND run_ts >= DATE_SUB(CURRENT_DATE(), 90) ORDER BY run_ts DESC LIMIT 200"
  }
 ],
