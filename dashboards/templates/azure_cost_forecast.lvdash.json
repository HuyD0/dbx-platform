            "spec": {
              "version": 1,
              "widgetType": "table",
              "encodings": {
                "columns": [
                  { "fieldName": "resource_group", "type": "string", "displayAs": "string", "visible": true, "order": 1, "title": "resource group", "displayName": "resource group" },
                  { "fieldName": "cost", "type": "float", "displayAs": "number", "visible": true, "order": 2, "title": "30d $", "displayName": "30d $" }
                ]
              },
              "frame": {
                "showTitle": true,
                "title": "Top resource groups — 30d",
                "showDescription": false
              }
            }
          },
          "position": { "x": 0, "y": 19, "width": 3, "height": 5 }
        },
        {
          "widget": {
            "name": "w_monitor_table",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_monitor",
                  "fields": [
                    { "name": "run_ts", "expression": "`run_ts`" },
                    { "name": "check_name", "expression": "`check_name`" },
                    { "name": "resource", "expression": "`resource`" },
                    { "name": "reason", "expression": "`reason`" },
                    { "name": "action", "expression": "`action`" }
                  ],
                  "disaggregated": true
                }
              }
            ],
            "spec": {
              "version": 1,
              "widgetType": "table",
              "encodings": {
