{
 "datasets": [
  {
   "name": "ds_requests_30d",
   "displayName": "ai_requests_30d",
   "query": "SELECT SUM(requests) AS requests FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30)"
  },
  {
   "name": "ds_errors_30d",
   "displayName": "ai_errors_30d",
   "query": "SELECT SUM(errors) AS errors FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30)"
  },
  {
   "name": "ds_apps_30d",
   "displayName": "ai_active_apps_30d",
   "query": "SELECT COUNT(DISTINCT app) AS apps FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30)"
  },
  {
   "name": "ds_daily_by_app",
   "displayName": "ai_daily_requests_by_app",
   "query": "SELECT usage_date, app, SUM(requests) AS requests FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 90) GROUP BY usage_date, app"
  },
  {
   "name": "ds_error_rate",
   "displayName": "ai_daily_error_rate_by_endpoint",
   "query": "SELECT usage_date, endpoint_name, ROUND(SUM(errors) / GREATEST(SUM(requests), 1) * 100, 2) AS error_pct FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30) GROUP BY usage_date, endpoint_name"
  },
  {
   "name": "ds_tokens_by_app",
   "displayName": "ai_tokens_by_app",
   "query": "SELECT app, SUM(input_tokens) AS input_tokens, SUM(output_tokens) AS output_tokens, SUM(input_tokens) + SUM(output_tokens) AS total_tokens FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30) GROUP BY app ORDER BY total_tokens DESC LIMIT 20"
  },
  {
   "name": "ds_requesters",
   "displayName": "ai_peak_requesters_by_endpoint",
   "query": "SELECT endpoint_name, MAX(distinct_requesters) AS peak_daily_requesters, SUM(requests) AS requests FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.serving.endpoint_usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30) GROUP BY endpoint_name ORDER BY requests DESC LIMIT 20"
  },
  {
   "name": "ds_latency",
   "displayName": "ai_p95_latency_by_endpoint",
   "query": "SELECT usage_date, endpoint_name, MAX(p95_latency_ms) AS p95_latency_ms FROM {catalog}.{schema}.ai_app_monitoring WHERE source = 'system.ai_gateway.usage' AND usage_date >= DATE_SUB(CURRENT_DATE(), 30) GROUP BY usage_date, endpoint_name"
  },
  {
   "name": "ds_findings",
   "displayName": "ai_monitor_findings",
   "query": "SELECT run_ts, check_name, resource, reason, action FROM {catalog}.{schema}.platform_findings WHERE area = 'ai-monitor' AND run_ts >= DATE_SUB(CURRENT_DATE(), 90) ORDER BY run_ts DESC LIMIT 200"
  }
 ],
